<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>متابعة تنفيذ الخطة التشغيلية 1448هـ</title>

<link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Cairo',sans-serif;
}

body{
background:#f4f7fb;
}

.header{
background:linear-gradient(135deg,#006c35,#008c4f);
color:white;
padding:25px;
text-align:center;
box-shadow:0 3px 10px rgba(0,0,0,.15);
}

.school-name{
font-family:'Aref Ruqaa',serif;
font-size:40px;
font-weight:bold;
margin-bottom:10px;
}

.info{
display:flex;
justify-content:center;
gap:30px;
flex-wrap:wrap;
font-size:18px;
}

.container{
padding:25px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:25px;
}

.card{
background:white;
padding:20px;
border-radius:15px;
text-align:center;
box-shadow:0 4px 10px rgba(0,0,0,.08);
transition:.3s;
}

.card:hover{
transform:translateY(-5px);
}

.card h3{
color:#666;
margin-bottom:10px;
}

.card span{
font-size:35px;
font-weight:bold;
color:#006c35;
}

.progress-box{
background:white;
padding:20px;
border-radius:15px;
margin-bottom:25px;
box-shadow:0 4px 10px rgba(0,0,0,.08);
}

.progress{
height:25px;
background:#ddd;
border-radius:20px;
overflow:hidden;
}

.progress-bar{
height:100%;
width:0%;
background:linear-gradient(90deg,#006c35,#00a85a);
color:white;
text-align:center;
line-height:25px;
font-weight:bold;
}

.table-box{
background:white;
padding:20px;
border-radius:15px;
box-shadow:0 4px 10px rgba(0,0,0,.08);
overflow:auto;
}

table{
width:100%;
border-collapse:collapse;
}

th{
background:#006c35;
color:white;
padding:12px;
}

td{
padding:10px;
border-bottom:1px solid #ddd;
text-align:center;
}

input,select{
padding:8px;
border:1px solid #ccc;
border-radius:8px;
width:100%;
}

.status-done{
background:#d4edda;
color:#155724;
padding:6px;
border-radius:8px;
}

.status-progress{
background:#fff3cd;
color:#856404;
padding:6px;
border-radius:8px;
}

.status-no{
background:#f8d7da;
color:#721c24;
padding:6px;
border-radius:8px;
}

.add-btn{
margin-top:15px;
background:#006c35;
color:white;
border:none;
padding:12px 25px;
border-radius:10px;
cursor:pointer;
font-size:16px;
}

.add-btn:hover{
background:#008c4f;
}

.footer{
margin-top:30px;
text-align:center;
color:#666;
font-size:14px;
}

</style>
</head>

<body>

<div class="header">

<div class="school-name">
مدرسة عبدالله بن مسعود الابتدائية
</div>

<div class="info">
<div>مدير المدرسة : محمد علي آل عبية</div>
<div>إعداد المعلم : عالي الغامدي</div>
<div>العام الدراسي : 1448هـ</div>
</div>

</div>

<div class="container">

<div class="cards">

<div class="card">
<h3>عدد البرامج</h3>
<span id="total">0</span>
</div>

<div class="card">
<h3>البرامج المنفذة</h3>
<span id="done">0</span>
</div>

<div class="card">
<h3>جاري التنفيذ</h3>
<span id="progressCount">0</span>
</div>

<div class="card">
<h3>غير المنفذة</h3>
<span id="notDone">0</span>
</div>

</div>

<div class="progress-box">

<h3 style="margin-bottom:10px">نسبة الإنجاز</h3>

<div class="progress">
<div class="progress-bar" id="progressBar">0%</div>
</div>

</div>

<div class="table-box">

<table id="planTable">

<thead>
<tr>
<th>اسم البرنامج</th>
<th>المجال</th>
<th>حالة التنفيذ</th>
<th>تاريخ التنفيذ</th>
<th>صور التنفيذ</th>
</tr>
</thead>

<tbody>

<tr>
<td><input type="text" placeholder="اسم البرنامج"></td>

<td>
<input type="text" placeholder="المجال">
</td>

<td>
<select onchange="updateDashboard()">
<option>لم يتم</option>
<option>جاري التنفيذ</option>
<option>تم</option>
</select>
</td>

<td>
<input type="date">
</td>

<td>
<input type="file" accept="image/*">
</td>

</tr>

</tbody>

</table>

<button class="add-btn" onclick="addRow()">
إضافة برنامج جديد
</button>

</div>

<div class="footer">
لوحة متابعة تنفيذ الخطة التشغيلية - الإصدار الاحترافي
</div>

</div>

<script>

function addRow(){

let table=document.querySelector("#planTable tbody");

let row=table.insertRow();

row.innerHTML=`

<td><input type="text"></td>

<td><input type="text"></td>

<td>
<select onchange="updateDashboard()">
<option>لم يتم</option>
<option>جاري التنفيذ</option>
<option>تم</option>
</select>
</td>

<td>
<input type="date">
</td>

<td>
<input type="file" accept="image/*">
</td>

`;

updateDashboard();

}

function updateDashboard(){

let selects=document.querySelectorAll("select");

let total=selects.length;
let done=0;
let progress=0;
let notDone=0;

selects.forEach(s=>{

if(s.value=="تم")
done++;

else if(s.value=="جاري التنفيذ")
progress++;

else
notDone++;

});

document.getElementById("total").textContent=total;
document.getElementById("done").textContent=done;
document.getElementById("progressCount").textContent=progress;
document.getElementById("notDone").textContent=notDone;

let percentage=total ? Math.round((done/total)*100) : 0;

document.getElementById("progressBar").style.width=percentage+"%";
document.getElementById("progressBar").innerHTML=percentage+"%";

}

updateDashboard();

</script>

</body>
</html>
